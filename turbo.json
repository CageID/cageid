{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["PORT", "DATABASE_URL", "OIDC_ISSUER", "JWT_PRIVATE_KEY", "JWT_PUBLIC_KEY", "UPSTASH_REDIS_REST_URL", "UPSTASH_REDIS_REST_TOKEN", "RESEND_API_KEY", "APP_BASE_URL", "VERIFF_API_KEY", "VERIFF_WEBHOOK_SECRET", "VERIFF_BASE_URL", "API_BASE_URL", "WEB_BASE_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
